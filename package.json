{
  "name": "automate-ai-platform",
  "version": "2.0.0",
  "description": "AI Agent-based Automation Platform — intelligent task planning, execution, and workflow automation",
  "homepage": "https://rehbar250.github.io/AutoMate",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node index.js",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "start": "cd server && node index.js",
    "predeploy": "cd client && npm run build",
    "deploy": "gh-pages -d client/dist"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "gh-pages": "^6.3.0",
    "vite": "^8.0.10"
  }
}
